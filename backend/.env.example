# App identity
PROJECT_NAME=GraphMind
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# API server
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# Frontend origins allowed by FastAPI CORS middleware.
# Keep this as JSON because pydantic-settings parses List[str] from env.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Upload and storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=[".md",".pdf",".txt",".docx",".py",".js",".ts"]
