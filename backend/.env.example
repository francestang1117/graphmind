# App identity
PROJECT_NAME=GraphMind
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# API server
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# Auth
# Generate a real value before deploying:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-change-me-before-deploy
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
REDIS_URL=redis://localhost:6379/0
# Keep false while there is no frontend login screen.
# Set true when every protected request sends Authorization: Bearer <token>.
AUTH_REQUIRED=false

# Database
# Local dev can use SQLite. Production should use PostgreSQL, for example:
# DATABASE_URL=postgresql+psycopg://graphmind:graphmind@postgres:5432/graphmind
DATABASE_URL=sqlite:///./graphmind.db

# Celery
# Reindex beat is off by default so local dev does not unexpectedly reprocess files.
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
CELERY_REINDEX_ENABLED=false
CELERY_REINDEX_INTERVAL_SECONDS=86400

# Entity extraction
# Extra spaCy models are optional. Missing models are skipped at startup.
SPACY_MODEL=en_core_web_sm
SPACY_EXTRA_MODELS=["zh_core_web_sm"]

# Rate limiting
# Uses REDIS_URL by default so limits are shared across API instances.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=
RATE_LIMIT_DEFAULT=200/day;50/hour
RATE_LIMIT_UPLOAD=10/minute;100/hour
RATE_LIMIT_CHAT=30/minute;500/day
RATE_LIMIT_SEARCH=60/minute
RATE_LIMIT_GRAPH_READ=120/minute
RATE_LIMIT_VIDEO=5/hour
RATE_LIMIT_SCRAPE=10/hour
TRUSTED_PROXY_IPS=["127.0.0.1","::1"]

# Frontend origins allowed by FastAPI CORS middleware.
# Keep this as JSON because pydantic-settings parses List[str] from env.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Upload and storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=[".md",".pdf",".txt",".docx",".py",".js",".ts",".json",".csv",".html",".htm"]

# Virus scanning
# Local dev can leave this off unless clamd is running.
# In production set VIRUS_SCAN_ENABLED=true and VIRUS_SCAN_FAIL_OPEN=false.
VIRUS_SCAN_ENABLED=false
VIRUS_SCAN_FAIL_OPEN=true
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=30

# Optional LLM layer for AI chat.
# Without this, chat still returns local retrieval-based answers.
OPENAI_API_KEY=
OPENAI_MODEL=
